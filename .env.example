# Copy to .env and fill (never commit .env)
# TigerGraph Cloud / REST
TG_HOST=https://your-instance.i.tgcloud.io
TG_GRAPHNAME=CHINTU
TG_USERNAME=
TG_PASSWORD=
TG_SECRET=
TG_RESTPP_PORT=443
TG_GS_PORT=443

