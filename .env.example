# Copy to .env and fill (never commit .env)
# TigerGraph Cloud / REST
TG_HOST=https://your-instance.i.tgcloud.io
TG_GRAPHNAME=CHINTU
TG_USERNAME=
TG_PASSWORD=
TG_SECRET=
# Cursor TigerGraph MCP often expects an API token (see MCP server docs). If MCP returns REST-10016, set
# TG_API_TOKEN (or the variable name your MCP README specifies) in the MCP server env, or use:
#   python scripts/install_chintu_query.py gsql/chintu_narrative_trace.gsql
# Backend token code uses HTTP Basic __GSQL__secret:<TG_SECRET> first; user/pass above are fallback.
TG_RESTPP_PORT=443
TG_GS_PORT=443

# Optional: set to 1 for strict TLS verify (default 0 matches typical Cloud setups)
# TG_VERIFY_SSL=0

# OpenAI-compatible API (backend LLM: intent + answers)
OPENAI_API_KEY=
# For project-scoped keys (sk-proj-...), set project id from dashboard (proj_...) — often required to avoid 401.
OPENAI_ORGANIZATION=org_YOUR_ORG_ID
OPENAI_PROJECT=proj_YOUR_PROJECT_ID
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: enable CORS for all origins (dev only)
# CHINTU_CORS=1

# Dotenv: default is override=True so .env wins over stale user/system OPENAI_API_KEY. Set to 0 to keep OS env priority.
# CHINTU_DOTENV_OVERRIDE=1

# Article fetch: on 404 or empty extract, retry via Jina Reader (https://r.jina.ai/<url>). Set to 0 to disable.
# CHINTU_JINA_READER=1

# Optional: override data locations
# CHINTU_EXPORT_DIR=        # default: ./data/chintu
# GDELT_RAW_DIR=            # default: ./experiments/data/gdelt_raw
# GDELT_ZIPS_DIR=           # default: ./experiments/data/gdelt_zips
# GENERATED_DATA_DIR=       # default: ./experiments/data/generated
