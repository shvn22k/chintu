# CHINTU Flask API (server-side proxy target — not exposed to the browser)
# Default if unset: http://127.0.0.1:5000
CHINTU_BACKEND_URL=http://127.0.0.1:5000

# Optional: max wait for chat/complete (ms). Default 180000.
# CHINTU_BACKEND_TIMEOUT_MS=180000

# Newsletter Express service (server-side only). Run: cd newsletter && npm start (default port 3001).
NEWSLETTER_SERVICE_URL=http://127.0.0.1:3001
